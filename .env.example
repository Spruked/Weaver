# Application
APP_NAME=Orb Weaver - Website ORB Intelligence Engine
DEBUG=True
VERSION=1.0.0
SECRET_KEY=change-this-in-production
ADMIN_TOKEN=change-this-local-admin-token
PUBLIC_BASE_URL=https://orbweaver.spruked.com

# Database
DATABASE_URL=sqlite:///./data/orb_weaver.db
REDIS_URL=redis://redis:6379/0

# Checkout
STRIPE_SECRET_KEY=
STRIPE_API_VERSION=2026-02-25.clover
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_API_BASE=https://api-m.paypal.com

# Google Analytics 4
GA4_PROPERTY_ID=your-ga4-property-id
GA4_CREDENTIALS_PATH=./ga4-credentials.json

# Crawler Settings
CRAWL_MAX_PAGES=1000
CRAWL_DELAY=1.0
CRAWL_TIMEOUT=30
CRAWL_USER_AGENT=Orb-Weaver/1.0
CRAWL_RESPECT_ROBOTS=True
CRAWL_MAX_DEPTH=5

# Audit Thresholds
MIN_PAGE_SPEED_SCORE=50
MAX_TITLE_LENGTH=60
MAX_META_DESC_LENGTH=160
MIN_CONTENT_WORDS=300
